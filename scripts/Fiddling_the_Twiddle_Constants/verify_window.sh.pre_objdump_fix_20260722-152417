#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/exp_env.sh"

SRC="$FIDDLE_REPO_ROOT/third_party/pqm4/mupq/pqclean/crypto_sign/dilithium2/clean/fiddling_twiddle_x86.c"
HDR="$FIDDLE_REPO_ROOT/third_party/pqm4/mupq/pqclean/crypto_sign/dilithium2/clean/fiddling_twiddle_x86.h"
MAIN="$FIDDLE_REPO_ROOT/targets/ravi_fiddling_twiddle/main.c"
BIN="$FIDDLE_BINARY"

[[ -f "$SRC" && -f "$HDR" && -f "$MAIN" && -x "$BIN" ]] || {
  echo "[error] source/header/main/binary missing" >&2
  exit 1
}

# Old, incorrect split attack models must be absent.
for obsolete in \
  FIDDLE_FAMILY_POINTER \
  FIDDLE_FAMILY_LOADED_VALUE \
  corrupt-loaded-twiddle-value \
  fiddle_target_group_corrupt_loaded_value \
  fiddle_stale_twiddle_zero \
  fiddle_wrong_index; do
  if grep -R -q "$obsolete" "$SRC" "$HDR" "$MAIN"; then
    echo "[error] obsolete split-attack marker remains: $obsolete" >&2
    exit 1
  fi
done

# Condition-2 and pointer selection are prepared outside measurement.
grep -Fq 'static int32_t fiddle_zero_twiddle_table[N]' "$SRC"
grep -Fq 'memset(' "$SRC"
grep -Fq 'fiddle_active_twiddle_pointer_literal =' "$SRC"
grep -Fq '? fiddle_zero_twiddle_table' "$SRC"
grep -Fq ': fiddle_correct_twiddle_pointer' "$SRC"

# One PC-relative pointer load site is shared by both modes.
grep -Fq 'fiddle_twiddle_pointer_load_site:' "$SRC"
grep -Fq 'movq fiddle_active_twiddle_pointer_literal(%%rip), %0' "$SRC"

# The expanded window must contain the pointer load plus the complete target NTT.
begin_line="$(
  grep -n 'fiddle_hpc_begin_unconditional();' "$SRC" |
  tail -n1 | cut -d: -f1
)"
runner_line="$(
  grep -n 'PQCLEAN_DILITHIUM2_CLEAN_fiddle_ntt_from_pointer_literal(a);' "$SRC" |
  head -n1 | cut -d: -f1
)"
end_line="$(
  grep -n 'fiddle_hpc_end_unconditional();' "$SRC" |
  tail -n1 | cut -d: -f1
)"
audit_line="$(
  grep -n 'Everything below is outside the PMU interval.' "$SRC" |
  head -n1 | cut -d: -f1
)"

[[ -n "$begin_line" && -n "$runner_line" &&
   -n "$end_line" && -n "$audit_line" ]] || {
  echo "[error] unable to resolve PMU source boundaries" >&2
  exit 1
}

(( begin_line < runner_line &&
   runner_line < end_line &&
   end_line < audit_line )) || {
  echo "[error] PMU window is not begin -> pointer-load/full-NTT -> end -> audit" >&2
  exit 1
}

DISASM="$(objdump -dr --no-show-raw-insn "$BIN")"
FUNCTION="$(
  awk '
    /<PQCLEAN_DILITHIUM2_CLEAN_fiddle_ntt_from_pointer_literal>:/ {
      found = 1
    }
    found { print }
    found && NF == 0 { exit }
  ' <<<"$DISASM"
)"

[[ -n "$FUNCTION" ]] || {
  echo "[error] pointer-literal NTT function absent from binary" >&2
  exit 1
}

grep -q 'fiddle_active_twiddle_pointer_literal' <<<"$FUNCTION" || {
  echo "[error] disassembly does not reference active pointer literal" >&2
  echo "$FUNCTION" >&2
  exit 1
}

# Baseline and attack semantics use the same binary and same target function.
"$BIN" --mode baseline --target-vec "$FIDDLE_TARGET_VEC" --self-test
"$BIN" --mode attack --target-vec "$FIDDLE_TARGET_VEC" --self-test

echo "[pass] obsolete two-attack simulation removed."
echo "[pass] zero twiddle array is prepared outside the PMU window."
echo "[pass] one shared RIP-relative pointer load models ldr r1,[pc,#4]."
echo "[pass] baseline loads T; attack loads T* pointing to the zero array."
echo "[pass] PMU window covers pointer load through the full target NTT."
echo "[pass] semantic self-tests passed for baseline and attack."
