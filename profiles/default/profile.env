#!/usr/bin/env bash
# Machine-specific settings belong here.

export HPC_CPU="${HPC_CPU:--1}"
export HPC_REPEATS="${HPC_REPEATS:-20}"
export HPC_ITERATIONS="${HPC_ITERATIONS:-200000}"

# Start with architectural events that are commonly exposed by Linux perf.
export HPC_EVENTS="${HPC_EVENTS:-cycles,instructions,branches,branch-misses,cache-references,cache-misses}"

# Add model-specific/raw events only after checking `perf list` on the server.
# Examples to evaluate separately:
# L1-dcache-loads,L1-dcache-load-misses,LLC-loads,LLC-load-misses
