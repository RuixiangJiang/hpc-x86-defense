#!/usr/bin/env bash
# Machine profile for the i7-13700K server.
# CPUs 0-15 are P-core logical CPUs; CPUs 16-23 are E-core logical CPUs.

# Use a P-core by default. Override with, for example, HPC_CPU=16 to test E-core.
export HPC_CPU="${HPC_CPU:-0}"

# "auto" selects cpu_core for a P-core CPU and cpu_atom for an E-core CPU.
export HPC_PMU="${HPC_PMU:-auto}"

export HPC_SELFTEST_ITERATIONS="${HPC_SELFTEST_ITERATIONS:-1000000}"
export HPC_MIN_RUNNING_PERCENT="${HPC_MIN_RUNNING_PERCENT:-95.0}"
